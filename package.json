{
  "name": "sanfrancisco",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node tools/precompress-dist.mjs",
    "precompress": "node tools/precompress-dist.mjs",
    "capture:reel": "node tools/capture-reel.mjs",
    "capture:reel2": "node tools/capture-reel2.mjs",
    "capture:reel3": "SF_CAPTURE_DEMO=reel3 SF_CAPTURE_SECONDS=25 node tools/capture-reel2.mjs",
    "capture:frames": "node tools/capture-frames.mjs",
    "capture:ggboat": "node tools/capture-boat.mjs",
    "preview": "vite preview",
    "server": "node server/server.mjs",
    "start": "node server/server.mjs",
    "check:aicars": "node --experimental-strip-types tools/check-aicars-checkpoint.mjs",
    "watch:aicars": "node tools/watch-aicars-training.mjs",
    "report:aicars": "node tools/summarize-aicars-training.mjs",
    "verify:aicars:overnight": "npm run report:aicars -- --min-strict-hours 8 --min-watchdog-passes 48 --max-step-m 8 --max-yaw-step-rad 0.35 && npm run check:aicars -- --min-stopline-holds 1 --max-trainer-log-age-s 180 --require-speed --max-road-clamps-per-km 12000 --max-lanefix-per-km 150 --min-progress-ratio 0.04 --max-stop-line-speed 0.35 --max-step-m 8 --max-yaw-step-rad 0.35 && npm run audit:traffic && node tools/check-road-collider-overlap.mjs",
    "audit:traffic": "node --experimental-strip-types tools/audit-traffic-system.mjs",
    "fetch:osm": "node tools/fetch-osm.mjs",
    "fetch:terrain": "node tools/fetch-terrain.mjs",
    "prepare:city": "node tools/prepare-city.mjs",
    "optimize:tiles": "node tools/optimize-tiles.mjs",
    "sync:box3d": "rm -rf vendor/box3d-wasm && mkdir -p vendor/box3d-wasm && cp -R ../box3d-wasm/packages/box3d-wasm/dist ../box3d-wasm/packages/box3d-wasm/package.json vendor/box3d-wasm/ && npm install"
  },
  "dependencies": {
    "box3d.js": "^0.0.2",
    "camera-controls": "^3.1.2",
    "lil-gui": "^0.21.0",
    "three": "^0.185.1",
    "tweakpane": "^4.0.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@tweakpane/core": "^2.0.5",
    "@types/three": "^0.185.0",
    "meshoptimizer": "^1.2.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.3.5"
  }
}
