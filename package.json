{
  "name": "sanfrancisco",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:hmr": "SF_FULL_RELOAD=1 vite",
    "dev:play": "SF_HMR=0 vite",
    "build": "tsc --noEmit && vite build && node tools/precompress-dist.mjs",
    "build:native-foliage-textures": "node tools/build-native-foliage-textures.mjs",
    "check:native-foliage-textures": "node tools/build-native-foliage-textures.mjs --check",
    "build:drum-bridge-textures": "node tools/build-drum-bridge-textures.mjs",
    "test:native-trees": "node --experimental-strip-types src/world/treeCompiler/probe.ts && node --experimental-strip-types src/world/vegetation/nativeTreeRecipes.probe.ts",
    "test:native-tree-lod-transition": "node --experimental-strip-types tools/native-tree-lod-transition-test.mjs",
    "precompress": "node tools/precompress-dist.mjs",
    "render:buskers": "node tools/render-buskers-cinematic.mjs",
    "render:cinematic": "node tools/render-cinematic.mjs",
    "render:cinematics": "node tools/render-cinematic.mjs --all --combine",
    "render:cinematics:fast": "node tools/render-cinematic.mjs --all --fast --combine",
    "render:hoverboard": "node tools/render-cinematic.mjs hoverboard --full",
    "render:hoverboard:fast": "node tools/render-cinematic.mjs hoverboard --fast",
    "render:dog-park": "node tools/render-cinematic.mjs dog-park --full",
    "render:dog-park:fast": "node tools/render-cinematic.mjs dog-park --fast",
    "render:palace-reverie": "node tools/render-cinematic.mjs palace-reverie --full",
    "render:palace-reverie:fast": "node tools/render-cinematic.mjs palace-reverie --fast",
    "render:phoenix-flyby": "node tools/render-cinematic.mjs phoenix-palace-flyby --full",
    "render:phoenix-flyby:fast": "node tools/render-cinematic.mjs phoenix-palace-flyby --fast",
    "render:roqn-open-road": "node tools/render-cinematic.mjs roqn-open-road --full",
    "render:roqn-open-road:fast": "node tools/render-cinematic.mjs roqn-open-road --fast",
    "render:twitter-summer": "node tools/render-twitter-summer.mjs",
    "deliver:x": "node tools/export-cinematic.mjs",
    "preview": "vite preview",
    "server": "node server/server.mjs",
    "start": "node server/server.mjs",
    "audit:traffic": "node --experimental-strip-types tools/audit-traffic-system.mjs",
    "test:golf": "node --experimental-strip-types tools/golf-logic-probe.mjs",
    "test:golf:terrain": "node --experimental-strip-types tools/golf-terrain-probe.mjs",
    "test:tea-garden": "node --experimental-strip-types tools/tea-garden-probe.mjs",
    "test:multiplayer-rake": "node tools/multiplayer-rake-probe.mjs",
    "test:multiplayer-rake:browser": "node tools/multiplayer-rake-browser-probe.mjs",
    "test:minigame-session": "node --experimental-strip-types tools/minigame-session-probe.mjs",
    "test:ocean-beach-kite": "node tools/ocean-beach-kite-probe.mjs",
    "test:sutro-baths": "node tools/sutro-baths-probe.mjs",
    "test:ghost-ship": "node --experimental-strip-types tools/ghost-ship-contract-test.mjs && node tools/ghost-ship-relay-probe.mjs",
    "test:drum-bridge": "node tools/drum-bridge-probe.mjs",
    "test:mission-dolores": "node --experimental-strip-types tools/mission-dolores-contract-test.mjs",
    "test:car-jump": "node --experimental-strip-types tools/car-jump-physics-probe.mjs",
    "test:player-audio": "node --experimental-strip-types tools/audio-mixer-probe.mjs && node --experimental-strip-types tools/player-foley-audio-probe.mjs && node --experimental-strip-types tools/jump-landing-audio-probe.mjs",
    "test:player-audio:browser": "node tools/player-audio-browser-probe.mjs",
    "test:car-customizer": "node tools/car-customizer-probe.mjs",
    "test:terrain-collision": "node tools/terrain-collision-probe.mjs",
    "test:terrain-clipmap": "node --experimental-strip-types tools/terrain-clipmap-probe.mjs",
    "test:terrain-assets": "node tools/terrain-asset-probe.mjs",
    "test:terrain-runtime": "node tools/terrain-runtime-probe.mjs",
    "test:roof-collision": "node tools/roof-collision-probe.mjs",
    "test:roof-visuals": "node tools/citygen-roof-visual-probe.mjs",
    "test:road-markings": "node tools/road-markings-depth-contract-test.mjs",
    "test:shadows:analysis": "node tools/shadow-temporal-analysis-test.mjs && node --experimental-strip-types tools/shadow-edge-contract-test.mjs",
    "test:shadows:temporal": "node tools/shadow-temporal-probe.mjs",
    "test:shadows:far-field": "node tools/far-occlusion-field-test.mjs",
    "test:shadows:contact": "node tools/contact-shadow-contract-test.mjs",
    "test:fog-weather": "node --experimental-strip-types tools/fog-weather-test.mjs",
    "test:palace-softness": "node --experimental-strip-types tools/palace-surface-softness-test.mjs",
    "test:ukiyo-postfx": "node tools/ukiyo-postfx-probe.mjs",
    "profile:shadows": "node tools/shadow-performance-probe.mjs",
    "test:hmr": "node --experimental-strip-types tools/hmr-lifecycle-probe.mjs",
    "test:hmr:browser": "node tools/hmr-browser-probe.mjs",
    "test:pointer-lock": "node tools/esc-pointerlock-probe.mjs",
    "test:avatar": "node tools/avatar-zfight-probe.mjs",
    "test:groundcover": "node --experimental-strip-types tools/grounding-fit-probe.mjs && node tools/groundcover-anchor-fade-probe.mjs",
    "fetch:osm": "node tools/fetch-osm.mjs",
    "fetch:terrain": "node tools/fetch-terrain.mjs",
    "prepare:city": "node tools/prepare-city.mjs",
    "landmarks:apply": "node tools/apply-authored-landmarks.mjs",
    "bake:region": "node tools/bake-authored-site.mjs",
    "bake:site": "node tools/bake-authored-site.mjs",
    "test:authored-regions": "node tools/validate-authored-regions.mjs",
    "optimize:tiles": "node tools/optimize-tiles.mjs",
    "sync:box3d": "rm -rf vendor/box3d-wasm && mkdir -p vendor/box3d-wasm && cp -R ../box3d-wasm/packages/box3d-wasm/dist ../box3d-wasm/packages/box3d-wasm/package.json vendor/box3d-wasm/ && npm install"
  },
  "dependencies": {
    "box3d.js": "^0.0.2",
    "camera-controls": "^3.1.2",
    "lil-gui": "^0.21.0",
    "satellite.js": "^6.0.2",
    "three": "^0.185.1",
    "tweakpane": "^4.0.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@tweakpane/core": "^2.0.5",
    "@types/three": "^0.185.0",
    "meshoptimizer": "^1.2.0",
    "playwright-core": "^1.61.1",
    "pngjs": "^7.0.0",
    "sharp": "^0.35.3",
    "typescript": "^5.7.2",
    "vite": "^6.3.5"
  }
}
